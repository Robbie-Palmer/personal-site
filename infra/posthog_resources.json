    "p75_cls_by_path_3284503": {
      "dashboard_keys": [
        "web_vitals_521311"
      ],
      "id": 3284503,
      "name": "p75 CLS by path",
      "query": {
        "chartSettings": {},
        "kind": "DataVisualizationNode",
        "source": {
          "explain": true,
          "filters": {
            "dateRange": {
              "date_from": "-7d",
              "date_to": null,
              "explicitDate": false
            },
            "filterTestAccounts": null,
            "properties": null
          },
          "kind": "HogQLQuery",
          "modifiers": null,
          "query": "SELECT \n    properties.$current_url AS current_url,\n    round(quantile(0.75)(properties.$web_vitals_CLS_value), 3) AS 'p75 CLS',\n    count() AS \"event count\"\nFROM events\nWHERE \n    {filters} AND\n    properties.$web_vitals_CLS_value IS NOT NULL\nGROUP BY properties.$current_url\nORDER BY \"event count\" DESC\nLIMIT 100",
          "response": null,
          "values": null
        },
        "tableSettings": {
