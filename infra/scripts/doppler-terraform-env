#!/usr/bin/env bash
set -euo pipefail

project="${DOPPLER_PROJECT:-personal-site}"
pages_env_config="${DOPPLER_PAGES_ENV_CONFIG:-dev_pages_env}"
infra_config="${DOPPLER_INFRA_CONFIG:-dev_infra}"

exec doppler run --project "$project" --config "$pages_env_config" -- doppler run \
  --project "$project" \
  --config "$infra_config" \
  --preserve-env=CF_IMAGES_ACCOUNT_HASH,NEXT_PUBLIC_CF_IMAGES_ACCOUNT_HASH,POSTHOG_KEY,NEXT_PUBLIC_POSTHOG_KEY,POSTHOG_HOST,NEXT_PUBLIC_POSTHOG_HOST,RECIPE_API_URL,RECIPE_API_PREVIEW_ORIGIN_TEMPLATE,CF_PAGES_HOST \
  -- bash -c '
set -euo pipefail

export TF_TOKEN_app_terraform_io="${TF_TOKEN_app_terraform_io:-${TF_API_TOKEN:-}}"
export TF_VAR_cf_images_account_hash="${TF_VAR_cf_images_account_hash:-${CF_IMAGES_ACCOUNT_HASH:-${NEXT_PUBLIC_CF_IMAGES_ACCOUNT_HASH:-}}}"
export TF_VAR_github_token="${TF_VAR_github_token:-${MISE_GITHUB_TOKEN:-${GITHUB_TOKEN:-}}}"
export TF_VAR_gcp_project_id="${TF_VAR_gcp_project_id:-${GCP_PROJECT_ID:-}}"
export TF_VAR_neon_org_id="${TF_VAR_neon_org_id:-${NEON_ORG_ID:-}}"
export TF_VAR_posthog_host="${TF_VAR_posthog_host:-${POSTHOG_HOST:-${NEXT_PUBLIC_POSTHOG_HOST:-}}}"
export TF_VAR_posthog_iac_enabled="${TF_VAR_posthog_iac_enabled:-${POSTHOG_IAC_ENABLED:-false}}"
export TF_VAR_posthog_key="${TF_VAR_posthog_key:-${POSTHOG_KEY:-${NEXT_PUBLIC_POSTHOG_KEY:-}}}"
export TF_VAR_posthog_project_id="${TF_VAR_posthog_project_id:-${POSTHOG_PROJECT_ID:-}}"
export TF_VAR_recipe_api_preview_origin_template="${TF_VAR_recipe_api_preview_origin_template:-${RECIPE_API_PREVIEW_ORIGIN_TEMPLATE:-}}"
export TF_VAR_recipe_api_url="${TF_VAR_recipe_api_url:-${RECIPE_API_URL:-}}"
export TF_VAR_cf_pages_host="${TF_VAR_cf_pages_host:-${CF_PAGES_HOST:-}}"

if [ "$TF_VAR_posthog_iac_enabled" = "true" ]; then
  export POSTHOG_API_KEY="${POSTHOG_API_KEY:-${POSTHOG_PERSONAL_API_KEY:-}}"
else
  export POSTHOG_API_KEY="${POSTHOG_API_KEY:-${POSTHOG_PERSONAL_API_KEY:-posthog-iac-disabled}}"
fi

exec "$@"
' doppler-terraform-env "$@"
