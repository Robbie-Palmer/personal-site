diff --git a/pkg/cooklang_wasm.js b/pkg/cooklang_wasm.js
index 27c98e1f3af1a6788f85517598e84516e5fa5794..36dcd956d6c016d037566e202aa5b9f97ea830fc 100644
--- a/pkg/cooklang_wasm.js
+++ b/pkg/cooklang_wasm.js
@@ -1,4 +1,24 @@
-import * as wasm from "./cooklang_wasm_bg.wasm";
+import * as wasmOrModule from "./cooklang_wasm_bg.wasm";
+import * as imports from "./cooklang_wasm_bg.js";
 export * from "./cooklang_wasm_bg.js";
 import { __wbg_set_wasm } from "./cooklang_wasm_bg.js";
+
+// Bundlers (vite, webpack, node) resolve the .wasm import to instantiated
+// exports, but Cloudflare's workerd resolves it to a WebAssembly.Module
+// (surfaced as the namespace default export). Instantiate it ourselves in
+// that case so both runtimes work. Reflect.get avoids webpack's static
+// export analysis, which rejects a direct .default access on wasm modules.
+const maybeModule =
+  wasmOrModule instanceof WebAssembly.Module
+    ? wasmOrModule
+    : Reflect.get(wasmOrModule, "default");
+const wasm =
+  maybeModule instanceof WebAssembly.Module
+    ? new WebAssembly.Instance(maybeModule, {
+        "./cooklang_wasm_bg.js": imports,
+      }).exports
+    : wasmOrModule;
 __wbg_set_wasm(wasm);
+if (typeof wasm.__wbindgen_start === "function") {
+  wasm.__wbindgen_start();
+}
