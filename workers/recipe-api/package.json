{
  "name": "recipe-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.scripts.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "bash scripts/test-integration.sh",
    "test:watch": "vitest",
    "db:check": "bash scripts/check-migrations.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "preview:seed": "tsx scripts/seed-preview.ts"
  },
  "dependencies": {
    "better-auth": "^1.6.19",
    "better-auth-cloudflare": "^0.3.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.7.11",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.1.3",
    "postgres": "^3.4.5",
    "recipe-db": "workspace:*",
    "recipe-domain": "workspace:*",
    "recipe-parsing": "workspace:*",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/node": "^24",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "wrangler": "^4"
  }
}
